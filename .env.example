# ────────────────────────────────────────────────────────
# PromptShare — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to Git.
# ────────────────────────────────────────────────────────

# App
APP_NAME=PromptShare
APP_URL=https://prompt.xpanda.in
APP_ENV=production

# Database (Hostinger MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u166258402_promptshare
DB_USERNAME=u166258402_promptshare
DB_PASSWORD=your_mysql_password_here

# Cache
CACHE_ENABLED=true
CACHE_TTL=60

# Google AdSense
# ADSENSE_ENABLED defaults to true — set false locally to skip the loader/slots.
# Slot IDs come from AdSense → Ads → By ad unit. Leave a slot empty and that
# placement falls back to a responsive auto unit.
ADSENSE_ENABLED=true
ADSENSE_CLIENT=ca-pub-3994115996677076
ADSENSE_SLOT_HOME_FEED=
ADSENSE_SLOT_PROMPT_TOP=
ADSENSE_SLOT_PROMPT_SIDE=

# Google OAuth
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://prompt.xpanda.in/auth/google/callback
